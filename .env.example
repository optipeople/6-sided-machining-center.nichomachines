# Public site URL — used by metadata and the API for the from-address host.
NEXT_PUBLIC_SITE_URL=https://6-sided-machining-center.nichomachines.com

# Resend (transactional email)
RESEND_API_KEY=

# Recipient for ROI submissions. Comma-separated list allowed.
# Falls back to CONTACT_TO_EMAIL, then to the hard-coded site.email.
ROI_TO_EMAIL=
CONTACT_TO_EMAIL=

# From-address for outgoing email. Defaults to website@<host of NEXT_PUBLIC_SITE_URL>.
CONTACT_FROM_EMAIL=
